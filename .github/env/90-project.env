# ================================================================================================
# 🏗️ PROJECT-SPECIFIC OVERRIDES (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific configuration overrides for arcade
# Load Order: 90 (loaded after all defaults, overrides earlier files)
#
# This file contains settings specific to this repository that should NOT be synced
# to other repositories via go-broadcast. All values here override defaults from
# earlier env files (00-core, 10-*, 20-*).
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION (overrides 00-core.env)
# ================================================================================================

GO_PRIMARY_VERSION=1.26.x
GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 🪄 MAGE-X VERSION OVERRIDES (overrides 10-mage-x.env)
# ================================================================================================

MAGE_X_GO_VERSION=1.26.x
MAGE_X_GO_SECONDARY_VERSION=1.26.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION (overrides 10-coverage.env)
# ================================================================================================

# Coverage provider (codecov for this project)
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration
CODECOV_TOKEN_REQUIRED=true

# Coverage exclusion paths (matches codecov.yml ignore list + standard exclusions)
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/

# ================================================================================================
# 🔒 SECURITY CVE EXCLUSIONS (overrides 10-security.env)
# ================================================================================================

# Nancy CVE Exclusions
NANCY_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-24051,CVE-2026-26014,CVE-2026-26958,CVE-2025-15558,CVE-2026-4427,CVE-2026-33809,CVE-2026-32286,CVE-2026-33747,CVE-2026-33748,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-35469,CVE-2026-5160,CVE-2026-39882,CVE-2026-33813,CVE-2026-33812

# Govulncheck/Magex CVE Exclusions
MAGE_X_CVE_EXCLUDES=CVE-2024-38513,CVE-2023-45142,CVE-2025-64702,CVE-2021-43668,CVE-2023-26248,CVE-2026-24051,CVE-2026-26014,CVE-2026-26958,CVE-2025-15558,CVE-2026-4427,CVE-2026-33809,CVE-2026-32286,CVE-2026-33747,CVE-2026-33748,CVE-2026-34986,CVE-2026-33815,CVE-2026-33816,CVE-2026-35469,CVE-2026-5160,CVE-2026-39882,CVE-2026-33813,CVE-2026-33812

# Skip pre-building packages during cache warming to prevent OOM kills.
# Even batch_size=3 with GOGC=50 exceeds the ~7GB available on standard runners
# because heavy packages (cmd/certifier, cmd/infra) pull in the entire dependency
# tree (libp2p, k8s, googleapis, etc.).
# The module cache (go mod download) is still warmed — that provides the biggest
# speedup. Build artifacts get cached naturally after the first real build job.
MAGE_X_BUILD_STRATEGY=skip
